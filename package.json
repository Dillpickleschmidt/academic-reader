{
	"name": "academic-reader",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.9",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"setup:dev": "bun scripts/setup-dev.ts",
		"dev": "bun scripts/dev.ts",
		"deploy:workers": "bun scripts/deploy-workers.ts",
		"dev:convex": "cd packages/convex && bun run dev",
		"check": "bun run check:web && bun run check:api && bun run check:convex && bun run check:shared",
		"check:web": "cd apps/web && bun run check",
		"check:api": "cd apps/api && bun run check",
		"check:convex": "cd packages/convex && bun run check",
		"check:shared": "cd packages/shared && bun run check",
		"format": "biome format --write .",
		"lint": "biome lint ."
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.5",
		"@types/bun": "^1.3.5",
		"typescript": "^6.0.2"
	}
}
