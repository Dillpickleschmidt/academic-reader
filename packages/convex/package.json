{
	"name": "@academic-reader/convex",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "CONVEX_AGENT_MODE=anonymous bun --env-file ../../.env.local node_modules/.bin/convex dev",
		"codegen": "convex codegen",
		"check": "tsc --noEmit && tsc --noEmit -p convex/tsconfig.json"
	},
	"exports": {
		"./api": {
			"types": "./convex/_generated/api.d.ts",
			"default": "./convex/_generated/api.js"
		},
		"./data-model": {
			"types": "./convex/_generated/dataModel.d.ts",
			"default": "./convex/_generated/dataModel.d.ts"
		}
	},
	"dependencies": {
		"@academic-reader/shared": "workspace:*",
		"@convex-dev/better-auth": "^0.10.9",
		"better-auth": "1.4.9",
		"convex": "^1.31.7"
	},
	"devDependencies": {
		"@types/node": "^24.10.1",
		"typescript": "^6.0.2"
	}
}
