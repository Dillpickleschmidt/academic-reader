# Generated by: bun run setup:dev
# Local defaults work without dashboard setup.

SITE_URL=http://localhost:5173
CONVEX_URL=http://localhost:3210
VITE_CONVEX_URL=http://localhost:3210
VITE_CONVEX_SITE_URL=http://localhost:3211

# Self-hosted Convex backend (runs in docker compose). Generated by setup-dev.
CONVEX_INSTANCE_NAME=academic-reader
# CONVEX_INSTANCE_SECRET=
CONVEX_SELF_HOSTED_URL=http://localhost:3210
# CONVEX_SELF_HOSTED_ADMIN_KEY=

# Storage backend: minio | s3
STORAGE_BACKEND=minio
S3_API_ENDPOINT=http://localhost:9000
S3_PRESIGNED_URL_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=academic-reader
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Conversion backend: local | modal
# local uses this machine's GPU; modal uses the hosted Marker worker.
CONVERSION_BACKEND=local
# MODAL_MARKER_URL=

# Narration audio backend: local | modal | none
TTS_BACKEND=local
KOKORO_TTS_WORKER_URL=http://localhost:8801
QWEN3_TTS_WORKER_URL=http://localhost:8802
# MODAL_KOKORO_TTS_URL=
# MODAL_QWEN3_TTS_URL=

# AI provider for Narration stages.
AI_PROVIDER=groq
# GROQ_API_KEY=
NARRATION_ELIGIBILITY_MODEL=openai/gpt-oss-120b
NARRATION_GUIDE_MODEL=openai/gpt-oss-120b
NARRATION_REWRITE_MODEL=openai/gpt-oss-120b

# Generated by setup-dev.
# BETTER_AUTH_SECRET=
# API_TO_CONVEX_SERVICE_SECRET=


# Optional Google sign-in.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
